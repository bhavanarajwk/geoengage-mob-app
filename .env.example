# Indoor Atlas SDK Credentials
# Get your credentials from https://app.indooratlas.com/apps
INDOORATLAS_API_KEY=your_api_key_here
INDOORATLAS_API_SECRET=your_api_secret_here

# Backend API Configuration
API_BASE_URL=https://api.geoengage.com

# Google Sign-In Configuration
# Get this from Firebase Console -> Project Settings -> General -> Web Client ID
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# App Configuration
DEFAULT_FLOOR_ID=1
